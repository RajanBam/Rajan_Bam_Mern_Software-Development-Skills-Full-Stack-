# Copy this file to ".env" and fill in real values.
PORT=5000

# Local MongoDB installed as a service (see README). Or use a MongoDB Atlas URI.
MONGODB_URI=mongodb://127.0.0.1:27017/inkboard

# Use a long random string in production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Where the React dev server runs (for CORS + Socket.IO origin).
CLIENT_ORIGIN=http://localhost:5173
