# Copy this file to ".env" and fill in real values.
PORT=5000

# --- Database ---
# Option A: local MongoDB installed as a service (see README).
MONGODB_URI=mongodb://127.0.0.1:27017/inkboard
#
# Option B: MongoDB Atlas (cloud). Put YOUR OWN connection string here in the real
# .env file (never commit real credentials). If the password contains special
# characters like ! or @, URL-encode them (e.g. ! becomes %21). Example shape:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/inkboard?retryWrites=true&w=majority

# Use a long random string in production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Where the React dev server runs (for CORS + Socket.IO origin).
CLIENT_ORIGIN=http://localhost:5173
